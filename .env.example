# ------------------------------
# Configuration Système 🖥️
# ------------------------------
TZ=Europe/Paris
# ID utilisateur (standard Raspberry Pi = 1000 / Mac = 501 souvent)
PUID=1000
PGID=1000

# ------------------------------
# Configuration Réseau & Ports 🌐
# ------------------------------
# Portainer (Interface de gestion)
PORTAINER_PORT=9000

# Homepage (Tableau de bord)
HOMEPAGE_PORT=3000

# Zensical (Documentation / Wiki)
ZENSICAL_PORT=8000

# ------------------------------
# Configuration Traefik & Domaines 🚦
# ------------------------------
# ATTENTION : Il faut des noms différents pour chaque service !

# Domaine pour Portainer
DOMAIN_PORTAINER=portainer.ton-domaine.duckdns.org

# Domaine pour Homepage
DOMAIN_HOMEPAGE=home.ton-domaine.duckdns.org

# Domaine pour le Wiki (Zensical)
DOMAIN_WIKI=wiki.ton-domaine.duckdns.org

# ------------------------------
# Configuration DuckDNS 🦆
# ------------------------------
# Ton token trouvé sur duckdns.org
DUCKDNS_TOKEN=ta-token-secrete-ici

# Liste de tes sous-domaines (ex: portainer,home,wiki)
# Important : Ne mets pas le domaine complet, juste le sous-domaine
DUCKDNS_SUBDOMAINS=portainer,home,wiki

# ------------------------------
# Configuration Let's Encrypt (SSL) 🔒
# ------------------------------
# Email pour les alertes de sécurité
ACME_EMAIL=ton-email@exemple.com

# ------------------------------
# Dossiers 📂
# ------------------------------
CONFIG_DIR=./config
IMAGES_DIR=./images